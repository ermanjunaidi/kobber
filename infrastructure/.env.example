# ── Traefik Dashboard (opsional) ──
# Buat password: echo $(htpasswd -nb admin passwordkamu) | sed 's/\$/\$\$/g'
TRAEFIK_USER=admin
TRAEFIK_PASSWORD_HASH=

# ── Cloudflare (untuk Let's Encrypt DNS challenge — opsional) ──
# Kalau mau HTTPS langsung dari Traefik (bukan dari Cloudflare Tunnel)
# CF_API_EMAIL=email@domain.com
# CF_DNS_API_TOKEN=your_token_here

# ── Domain utama ──
ROOT_DOMAIN=raportns.my.id
